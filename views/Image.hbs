<div class="row">
  <div class="col s12 m10 offset-m1">
    <div class="card">
      <div class="card-image">
        <img src="/data/{{file}}" alt="{{file}}" loading="lazy">
        <span class="card-title">{{file}}</span>
      </div>
      <div class="card-content">
        <p><strong>Dateiname:</strong> {{file}}</p>
        <p><strong>Größe:</strong> {{humanFileSize size}}</p>
        <p><strong>Geändert:</strong> {{prettifyDate mtime}}</p>
        <p><strong>Typ:</strong> {{type}}</p>
      </div>
      <div class="card-action">
        <form action="/download" method="post" style="display:inline-block; margin-right: 1rem;">
          <input type="hidden" name="target" value="{{file}}">
          <button class="btn" type="submit">Herunterladen</button>
        </form>
        <a class="btn grey" href="/Galerie">Zurück zur Galerie</a>
      </div>
    </div>
  </div>
</div>
