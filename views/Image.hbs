<div class="row">
  <div class="col s12 m10 offset-m1">
    <div class="card">
      <div class="card-image">
        <img src="/data/{{file}}" alt="{{file}}" loading="lazy">
        <span class="card-title">{{file}}</span>
      </div>
      <div class="card-content">
        <p><strong>Dateiname:</strong> {{file}}</p>
        <p><strong>Größe:</strong> {{humanFileSize size}}</p>
        <p><strong>Geändert:</strong> {{prettifyDate mtime}}</p>
        <p><strong>Typ:</strong> {{type}}</p>
      </div>
      <div class="card-action">
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          {{#if previousImage}}
            <a class="btn light-blue" href="/image/{{previousImage}}"><i class="fas fa-chevron-left"></i> Zurück</a>
          {{/if}}
          <form action="/download" method="post" style="display:inline-block;">
            <input type="hidden" name="target" value="{{file}}">
            <button class="btn" type="submit">Herunterladen</button>
          </form>
          {{#if nextImage}}
            <a class="btn light-blue" href="/image/{{nextImage}}">Weiter <i class="fas fa-chevron-right"></i></a>
          {{/if}}
          <a class="btn grey" href="/Galerie">Zur Galerie</a>
        </div>
      </div>
    </div>
  </div>
</div>
