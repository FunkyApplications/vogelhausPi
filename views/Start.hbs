

      <!--   Latest Media Preview   -->
      {{#if latestMedia}}
      <div class="row">
        <div class="col s12">
          <div class="card">
            <div class="card-content center">
              <span class="card-title">Letztes Bild/Video</span>
              {{#if (eq latestMedia.ext "png")}}
                <img src="/data/{{latestMedia.name}}" alt="Latest" style="max-width: 100%; max-height: 300px; border-radius: 4px;">
              {{else}}
                <video width="100%" height="300" style="border-radius: 4px;" controls>
                  <source src="/data/{{latestMedia.name}}" type="video/mp4">
                  Ihr Browser unterstützt HTML5 Video nicht.
                </video>
              {{/if}}
              <p class="grey-text text-darken-2">{{latestMedia.name}}</p>
            </div>
          </div>
        </div>
      </div>
      {{/if}}

      <!--   Icon Section   -->
      <div class="row">
        <div class="col s12 m4">
          <div class="icon-block">
            <h2 class="center light-blue-text"><a href="/takePicture"><i class="fas fa-camera-retro"></i></a></h2>
            <h5 class="center">Foto erstellen</h5>

            <p class="light">Durch einen Klick auf das Icon wir ein Foto im Format png erstellt. Die Erstellung dauert einige Sekunden. Das fertige Foto ist dann in der Galerie verfügbar. </p>
          </div>
        </div>

        <div class="col s12 m4">
          <div class="icon-block">
            <h2 class="center light-blue-text"><a href="/takeVideo"><i class="fas fa-video"></i></a></h2>
            <h5 class="center">Kurzvideo erstellen</h5>

            <p class="light">Durch einen Klick auf das Icon wird ein kurzes Video im Format h264 erstellt. Dieses kann dann angeschaut und heruntergeladen werden. </p>
          </div>
        </div>

        <div class="col s12 m4">
          <div class="icon-block">
            <h2 class="center light-blue-text"><a href="/Galerie"><i class="fas fa-images"></i></a> </h2>
            <h5 class="center">Galerie</h5>

            <p class="light">Hier gelangt man zur Galerie. Dort kann man Daten herunterladen und auch Entfernen.</p>
          </div>
        </div>
      </div>
